#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__.'/../vendor/autoload.php';

use Vladislavmakarov\BitrixHackathon2026\App\CharacterFactory;
use Vladislavmakarov\BitrixHackathon2026\App\CharacterService;
use Vladislavmakarov\BitrixHackathon2026\App\FeedingService;
use Vladislavmakarov\BitrixHackathon2026\Integration\ErrorLog;
use Vladislavmakarov\BitrixHackathon2026\Integration\HookHandlers;
use Vladislavmakarov\BitrixHackathon2026\Integration\HooksInstaller;
use Vladislavmakarov\BitrixHackathon2026\Integration\PetConsoleView;
use Vladislavmakarov\BitrixHackathon2026\Integration\PetListView;
use Vladislavmakarov\BitrixHackathon2026\Integration\SkillCatalog;
use Vladislavmakarov\BitrixHackathon2026\Storage\CharacterRepository;
use Vladislavmakarov\BitrixHackathon2026\Storage\Paths;
use Vladislavmakarov\BitrixHackathon2026\Storage\SessionStore;
use Vladislavmakarov\BitrixHackathon2026\Storage\SystemClock;
use Vladislavmakarov\BitrixHackathon2026\Tui\MenuApp;

// §2.3 SDD-B (path 1): composition root на РЕАЛЬНЫХ классах блока A —
// сервисы B тайп-хинтят интерфейсы, реальные классы их реализуют.
$clock     = new SystemClock();
$paths     = new Paths();
$repo      = new CharacterRepository($paths->dataDir());
$sessions  = new SessionStore($paths->dataDir());
$charFac   = new CharacterFactory($clock);
$catalog   = new SkillCatalog($paths);
$feeding   = new FeedingService($repo, $sessions, $clock, $charFac);
$charSvc   = new CharacterService($repo, $catalog, $charFac);
$view      = new PetConsoleView();
$listView  = new PetListView();
$log       = new ErrorLog($paths);
$hooks     = new HookHandlers($feeding, $sessions, $view, $clock, $log);
$installer = new HooksInstaller($paths);

/** @param string[] $args */
function tamagotchi_parse_flags(array $args): array
{
    $flags = [];
    foreach ($args as $arg) {
        if (!str_starts_with($arg, '--')) {
            continue;
        }
        $pair = substr($arg, 2);
        [$key, $value] = str_contains($pair, '=') ? explode('=', $pair, 2) : [$pair, ''];
        $flags[$key] = $value;
    }

    return $flags;
}

function tamagotchi_help(): string
{
    return <<<'TEXT'
    Тамагочи для кодового агента — консольная утилита.

    Использование: tamagotchi <команда> [аргументы]

    Команды:
      (нет команды)                                запустить TUI (блок C)
      setup                                         установить хуки Claude Code в settings.json
      list                                          показать список питомцев
      create --skill=<s> --name=<n> [--type=<t>]    создать питомца
      delete <id>                                   удалить питомца
      hook:tool-use                                 внутренний обработчик хука PostToolUse
      hook:prompt                                   внутренний обработчик хука UserPromptSubmit
      hook:session-end                              внутренний обработчик хука SessionEnd
      help                                          показать эту справку

    TEXT;
}

$command = $argv[1] ?? null;

switch ($command) {
    case 'setup':
        try {
            $installer->install((string) realpath(__FILE__));
            fwrite(STDOUT, "Хуки установлены.\n");
            exit(0);
        } catch (Throwable $e) {
            fwrite(STDERR, 'setup: '.$e->getMessage()."\n");
            exit(1);
        }

    case 'list':
        $pets = $repo->all();
        if ($pets === []) {
            fwrite(STDOUT, "Питомцев пока нет. Заведи: bin/tamagotchi create --skill=<skill> --name=<имя>\n");
            exit(0);
        }
        fwrite(STDOUT, $listView->renderList($pets, $clock->today()));
        exit(0);

    case 'create':
        $flags = tamagotchi_parse_flags(array_slice($argv, 2));
        $skill = trim($flags['skill'] ?? '');
        $name = trim($flags['name'] ?? '');
        $type = $flags['type'] ?? null;

        if ($skill === '') {
            fwrite(STDERR, "create: укажи скилл через --skill=<skill>\n");
            exit(1);
        }
        // §9.2 OQ-N1: имя обязательно в CLI (без дефолта из скилла).
        if ($name === '') {
            fwrite(STDERR, "create: укажи имя питомца через --name=<имя>\n");
            exit(1);
        }

        // §9.2 OQ-N2: валидация скилла мягкая — предупреждение, не отказ.
        $knownSkills = $catalog->all();
        if ($knownSkills !== [] && !in_array($skill, $knownSkills, true)) {
            fwrite(STDOUT, sprintf("⚠️  Скилл «%s» не найден среди локальных скиллов — питомца всё равно создаю.\n", $skill));
        }

        try {
            $pet = $charSvc->create($name, $skill, $type);
            fwrite(STDOUT, sprintf("🎉 Питомец «%s» создан (скилл: %s, id: %s).\n", $pet->name(), $pet->skill(), $pet->id()));
            exit(0);
        } catch (Throwable $e) {
            fwrite(STDERR, 'create: '.$e->getMessage()."\n");
            exit(1);
        }

    case 'delete':
        $id = $argv[2] ?? null;
        if ($id === null) {
            fwrite(STDERR, "delete: нужен id питомца\n");
            exit(1);
        }
        try {
            $charSvc->delete($id);
            fwrite(STDOUT, "Питомец удалён.\n");
            exit(0);
        } catch (Throwable $e) {
            fwrite(STDERR, 'delete: '.$e->getMessage()."\n");
            exit(1);
        }

    case 'hook:tool-use':
        exit($hooks->handleToolUse());

    case 'hook:prompt':
        exit($hooks->handlePrompt());

    case 'hook:session-end':
        exit($hooks->handleSessionEnd());

    case 'help':
        fwrite(STDOUT, tamagotchi_help());
        exit(0);

    case null:
        // §4.8 SDD-B: без аргументов -> TUI (блок C). MenuApp::run() сам решает
        // TTY/non-TTY (в non-TTY делегирует в PlainRenderer).
        // Установку хуков кодового агента отдаём в TUI отдельным пунктом меню:
        // MenuApp получает колбэк, который зовёт HooksInstaller (блок B).
        $binPath = (string) realpath(__FILE__);
        $setupHooks = static function () use ($installer, $binPath): string {
            try {
                $installer->install($binPath);

                return '✅ Хуки установлены в settings.json.'."\n"
                    .'Перезапусти сессию Claude Code — после этого каждое использование'."\n"
                    .'скилла будет кормить питомца, а конец сессии подводить итог.';
            } catch (Throwable $e) {
                return '⚠️ Не удалось установить хуки: '.$e->getMessage();
            }
        };
        $menuApp = new MenuApp($repo, $charSvc, $catalog, $clock, null, null, $setupHooks);
        exit($menuApp->run());

    default:
        fwrite(STDERR, sprintf("Неизвестная команда: %s\n\n", $command));
        fwrite(STDERR, tamagotchi_help());
        exit(1);
}
